# .env.example — 환경 설정 자리표시자 템플릿
# 사용: 이 파일을 .env로 복사 후 자기 환경 값으로 수정 (`.env`는 gitignore됨)

# --- MySQL DB 연결 ---
DB_USER=your_user
DB_PASSWORD=your_password
DB_HOST=localhost
DB_NAME=fashion_platform

# --- KoNLPy Java 의존성 (07_text_analysis.ipynb에서 사용) ---
# Okt 형태소 분석기는 Java 11 이상 필요. JDK 설치 후 JAVA_HOME 경로 입력.
#
# 환경별 설치·경로 예시
#   macOS (Homebrew):   brew install openjdk@11
#     JAVA_HOME=/opt/homebrew/opt/openjdk@11/libexec/openjdk.jdk/Contents/Home
#   Linux (Ubuntu/Debian apt): sudo apt install openjdk-11-jdk
#     JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64
#   Linux (RHEL/CentOS yum): sudo yum install java-11-openjdk-devel
#     JAVA_HOME=/usr/lib/jvm/java-11-openjdk
#   Windows: Oracle JDK 또는 Adoptium 설치 후 설치 디렉토리
#     JAVA_HOME=C:\Program Files\Eclipse Adoptium\jdk-11.0.x-hotspot
JAVA_HOME=/path/to/your/jdk

# --- 한글 폰트 (07_text_analysis.ipynb 워드클라우드에서 사용) ---
# 비워두면 OS별 표준 경로 자동 탐색 → 그것도 없으면 matplotlib 영문 폰트 fallback
# 자동 탐색이 실패할 때 또는 다른 폰트 강제 시에만 명시
#
# 환경별 표준 경로 예시
#   macOS: /System/Library/Fonts/AppleSDGothicNeo.ttc
#   Linux (Nanum 설치 후): /usr/share/fonts/truetype/nanum/NanumGothic.ttf
#     설치: sudo apt install fonts-nanum  (Ubuntu/Debian)
#   Windows: C:/Windows/Fonts/malgun.ttf
FONT_PATH=
